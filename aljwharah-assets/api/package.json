{
    "name": "api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/main.js",
        "start:dev": "npx ts-node --project tsconfig.json src/main.ts",
        "start:prod": "node dist/main.js",
        "test": "jest",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "db:migrate": "node dist/database/run-migrations.js"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/throttler": "^6.5.0",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.13.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^11.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.0",
        "@types/ioredis": "^4.28.10",
        "@types/jest": "^29.5.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.0",
        "@types/uuid": "^10.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.7.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
